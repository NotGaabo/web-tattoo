        <record id="availability_carlos_mon" model="tattoo.artist.availability">
            <field name="artist_id" ref="artist_carlos"/>
            <field name="day_of_week">0</field>
            <field name="start_time">10.0</field>
            <field name="end_time">18.0</field>
        </record>

        <record id="availability_carlos_tue" model="tattoo.artist.availability">
            <field name="artist_id" ref="artist_carlos"/>
            <field name="day_of_week">1</field>
            <field name="start_time">10.0</field>
            <field name="end_time">18.0</field>
        </record>

        <record id="availability_carlos_wed" model="tattoo.artist.availability">
            <field name="artist_id" ref="artist_carlos"/>

        </record>

        <record id="availability_carlos_fri" model="tattoo.artist.availability">
            <field name="artist_id" ref="artist_carlos"/>
            <field name="day_of_week">4</field>
            <field name="start_time">10.0</field>
            <field name="end_time">18.0</field>
        </record>

        <!-- Example Exception -->
        <record id="exception_closed_2024_04_24" model="tattoo.exception">
            <field name="date">2024-04-24</field>
            <field name="reason">Vacaciones - Estudio cerrado</field>
            <field name="is_closed">True</field>
        </record>

        <!-- Artists -->
        <record id="artist_carlos" model="tattoo.artist">
            <field name="name">Carlos Martínez</field>
            <field name="email">carlos@tattoostudio.com</field>
            <field name="phone">+34 666 111 111</field>
            <field name="specialization">Realism in Black and White</field>
            <field name="years_of_experience">12</field>
            <field name="biography">Expert in realistic tattoos with incredible details. My passion is creating works of art on skin.</field>
            <field name="skill_ids" eval="[(4, ref('skill_realism'))]"/>
            <field name="service_ids" eval="[(4, ref('service_small')), (4, ref('service_medium')), (4, ref('service_large'))]"/>
        </record>

        <record id="artist_luna" model="tattoo.artist">
            <field name="name">Luna González</field>
            <field name="email">luna@tattoostudio.com</field>
            <field name="phone">+34 666 111 112</field>
            <field name="specialization">Minimalist Tattoos</field>
            <field name="years_of_experience">8</field>
            <field name="biography">I create simple but impactful designs that speak for themselves. Less is more.</field>
            <field name="skill_ids" eval="[(4, ref('skill_minimalism'))]"/>
            <field name="service_ids" eval="[(4, ref('service_small')), (4, ref('service_medium'))]"/>
        </record>

        <record id="artist_david" model="tattoo.artist">
            <field name="name">David Silva</field>
            <field name="email">david@tattoostudio.com</field>
            <field name="phone">+34 666 111 113</field>
            <field name="specialization">Traditional and Neo-Traditional</field>
            <field name="years_of_experience">10</field>
            <field name="biography">Specialist in classic tattoos with a modern touch. Vibrant colors and precise lines.</field>
            <field name="skill_ids" eval="[(4, ref('skill_traditional'))]"/>
            <field name="service_ids" eval="[(4, ref('service_medium')), (4, ref('service_large'))]"/>
        </record>
    </data>
</odoo>

        <!-- Skills -->
        <record id="skill_realism" model="tattoo.skill">
            <field name="name">Realism</field>
            <field name="description">Realistic and detailed tattoo designs</field>
        </record>

        <record id="skill_minimalism" model="tattoo.skill">
            <field name="name">Minimalism</field>
            <field name="description">Simple, elegant minimalist designs</field>
        </record>

        <record id="skill_traditional" model="tattoo.skill">
            <field name="name">Traditional</field>
            <field name="description">Classic traditional tattoo style</field>
        </record>

        <record id="skill_watercolor" model="tattoo.skill">
            <field name="name">Watercolor</field>
            <field name="description">Watercolor and artistic designs</field>
        </record>

        <record id="skill_biomechanical" model="tattoo.skill">
            <field name="name">Biomechanical</field>
            <field name="description">Biomechanical and sci-fi designs</field>
        </record>

        <!-- Services -->
        <record id="service_small" model="tattoo.service">
            <field name="name">Small Tattoo</field>
            <field name="service_type">small</field>
            <field name="base_price">80</field>
            <field name="estimated_time_hours">0.75</field>
            <field name="available_colors">black</field>
            <field name="description">Small tattoos (up to 5cm²). Perfect for first tattoos or simple designs.</field>
        </record>

        <record id="service_medium" model="tattoo.service">
            <field name="name">Medium Tattoo</field>
            <field name="service_type">medium</field>
            <field name="base_price">150</field>
            <field name="estimated_time_hours">2</field>
            <field name="available_colors">all</field>
            <field name="description">Medium tattoos (5-20cm²). Great variety of designs and styles.</field>
        </record>

        <record id="service_large" model="tattoo.service">
            <field name="name">Large Tattoo</field>
            <field name="service_type">large</field>
            <field name="base_price">300</field>
            <field name="estimated_time_hours">4</field>
            <field name="available_colors">all</field>
            <field name="description">Large tattoos with lots of detail. May require multiple sessions.</field>
        </record>

        <!-- Products -->
        <record id="tmpl_product_aftercare_cream" model="product.template">
            <field name="name">Premium Aftercare Cream</field>
            <field name="code">PROD-001</field>
            <field name="brand">TattooLux</field>
            <field name="list_price">24.99</field>
            <field name="standard_price">8.00</field>
            <field name="description">Premium aftercare cream for tattoo healing. Deep hydration and protection.</field>
            <field name="weight">50</field>
        </record>

        <record id="tmpl_product_protective_balm" model="product.template">
            <field name="name">Protective Balm</field>
            <field name="code">PROD-002</field>
            <field name="brand">SkinShield</field>
            <field name="list_price">19.99</field>
            <field name="standard_price">6.00</field>
            <field name="description">Protective balm with natural ingredients for optimal scarring.</field>
            <field name="weight">30</field>
        </record>

        <record id="tmpl_product_healing_lotion" model="product.template">
            <field name="name">Healing Lotion</field>
            <field name="code">PROD-003</field>
            <field name="brand">InkCare</field>
            <field name="list_price">21.99</field>
            <field name="standard_price">7.00</field>
            <field name="description">Healing lotion specially formulated for fresh tattoos.</field>
            <field name="weight">60</field>
        </record>


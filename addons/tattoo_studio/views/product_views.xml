<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tattoo Product List View -->
    <record id="view_tattoo_product_list" model="ir.ui.view">
        <field name="name">product.template.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="Products">
                <field name="image_128" widget="image" optional="show"/>
                <field name="name"/>
                <field
                    name="brand_id"
                    context="{'default_active': True}"
                    options="{'no_quick_create': False, 'no_create_edit': False, 'no_open': False}"
                />
                <field name="list_price"/>
                <field name="quantity_available"/>
                <field name="average_rating"/>
                <field name="total_reviews"/>
            </list>
        </field>
    </record>

    <!-- Tattoo Product Form View -->
    <record id="view_tattoo_product_form" model="ir.ui.view">
        <field name="name">product.template.form</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <form string="Product">
                <sheet>
                    <h1>
                        <field name="name" placeholder="Product Name"/>
                    </h1>
                    <group>
                        <group string="Product Information">
                            <field name="image_1920" widget="image" class="oe_avatar"/>
                            <field name="code"/>
                            <field
                                name="brand_id"
                                context="{'default_active': True}"
                                options="{'no_quick_create': False, 'no_create_edit': False, 'no_open': False}"
                                placeholder="Select or create a brand"
                            />
                            <field name="category_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Pricing">
                            <field name="standard_price"/>
                            <field name="list_price"/>
                        </group>
                    </group>
                    <group>
                        <group string="Inventory">
                            <field name="quantity_available"/>
                            <field name="quantity_reserved"/>
                            <field name="weight"/>
                            <field name="volume"/>
                        </group>
                        <group string="Ratings">
                            <field name="average_rating"/>
                            <field name="total_reviews"/>
                            <field name="total_sales"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Usage Instructions" name="instructions">
                            <field name="usage_instructions"/>
                        </page>
                        <page string="Reviews" name="reviews">
                            <field name="review_ids" readonly="1">
                                <list>
                                    <field name="customer_id"/>
                                    <field name="rating"/>
                                    <field name="review_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_product" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage tattoo aftercare products</field>
    </record>

    <record id="view_tattoo_product_brand_list" model="ir.ui.view">
        <field name="name">tattoo.product.brand.list</field>
        <field name="model">tattoo.product.brand</field>
        <field name="arch" type="xml">
            <list string="Brands">
                <field name="name"/>
                <field name="product_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tattoo_product_brand_form" model="ir.ui.view">
        <field name="name">tattoo.product.brand.form</field>
        <field name="model">tattoo.product.brand</field>
        <field name="arch" type="xml">
            <form string="Brand">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="product_count" readonly="1"/>
                    </group>
                    <group string="Products">
                        <field name="product_ids" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="list_price"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_product_brand" model="ir.actions.act_window">
        <field name="name">Brands</field>
        <field name="res_model">tattoo.product.brand</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage product brands used by the catalog</field>
    </record>
</odoo>

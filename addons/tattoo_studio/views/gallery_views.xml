<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tattoo_artist_gallery_list" model="ir.ui.view">
        <field name="name">tattoo.artist.gallery.list</field>
        <field name="model">tattoo.artist.gallery</field>
        <field name="arch" type="xml">
            <list string="Gallery">
                <field name="sequence"/>
                <field name="name"/>
                <field name="artist_id"/>
                <field name="tattoo_type"/>
                <field name="work_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tattoo_artist_gallery_form" model="ir.ui.view">
        <field name="name">tattoo.artist.gallery.form</field>
        <field name="model">tattoo.artist.gallery</field>
        <field name="arch" type="xml">
            <form string="Gallery Work">
                <sheet>
                    <div class="oe_title">
                        <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="artist_id"/>
                            <field name="tattoo_type"/>
                        </group>
                        <group>
                            <field name="work_date"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_artist_gallery" model="ir.actions.act_window">
        <field name="name">Gallery</field>
        <field name="res_model">tattoo.artist.gallery</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage tattoo gallery pieces by artist and style</field>
    </record>
</odoo>

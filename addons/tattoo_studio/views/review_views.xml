<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tattoo Review List View -->
    <record id="view_tattoo_review_list" model="ir.ui.view">
        <field name="name">tattoo.review.list</field>
        <field name="model">tattoo.review</field>
        <field name="arch" type="xml">
            <list string="Reviews" decoration-success="state=='approved'">
                <field name="customer_id"/>
                <field name="review_type"/>
                <field name="title"/>
                <field name="rating"/>
                <field name="state"/>
                <field name="verified_purchase"/>
            </list>
        </field>
    </record>

    <!-- Tattoo Review Form View -->
    <record id="view_tattoo_review_form" model="ir.ui.view">
        <field name="name">tattoo.review.form</field>
        <field name="model">tattoo.review</field>
        <field name="arch" type="xml">
            <form string="Review">
                <header>
    <button name="action_submit" string="Submit for Review" type="object"
        invisible="state != 'draft'" class="btn-primary"/>

    <button name="action_approve" string="Approve" type="object"
        invisible="state != 'submitted'" class="btn-primary"/>

    <button name="action_reject" string="Reject" type="object"
        invisible="state != 'submitted'" class="btn-secondary"/>

    <field name="state" widget="statusbar"
        statusbar_visible="draft,submitted,approved,rejected"/>
</header>
                <sheet>
                    <group>
                        <group string="Review Information">
                            <field name="customer_id"/>
                            <field name="review_type"/>
                            <field name="review_date"/>
                            <field name="verified_purchase"/>
                        </group>
                        <group string="Content">
                            <field name="title"/>
                            <field name="rating" widget="star"/>
                        </group>
                    </group>
                    <group>
                       <field name="product_id" invisible="review_type != 'product'"/>
<field name="service_id" invisible="review_type != 'service'"/>
<field name="artist_id" invisible="review_type != 'artist'"/>
 </group>
                    <notebook>
                        <page string="Comment" name="comment">
                            <field name="comment" nolabel="1"/>
                        </page>
                        <page string="Engagement" name="engagement">
                            <group>
                                <field name="helpful_count"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_review" model="ir.actions.act_window">
        <field name="name">Reviews</field>
        <field name="res_model">tattoo.review</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage customer reviews</field>
    </record>
</odoo>

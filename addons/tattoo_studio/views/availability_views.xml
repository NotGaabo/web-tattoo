<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tattoo Artist Availability List View -->
    <record id="view_tattoo_artist_availability_list" model="ir.ui.view">
        <field name="name">tattoo.artist.availability.list</field>
        <field name="model">tattoo.artist.availability</field>
        <field name="arch" type="xml">
            <list string="Availability">
                <field name="artist_id"/>
                <field name="day_of_week"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Tattoo Artist Availability Form View -->
    <record id="view_tattoo_artist_availability_form" model="ir.ui.view">
        <field name="name">tattoo.artist.availability.form</field>
        <field name="model">tattoo.artist.availability</field>
        <field name="arch" type="xml">
            <form string="Availability">
                <sheet>
                    <group>
                        <field name="artist_id"/>
                        <field name="day_of_week"/>
                        <field name="start_time"/>
                        <field name="end_time"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_artist_availability" model="ir.actions.act_window">
        <field name="name">Artist Availability</field>
        <field name="res_model">tattoo.artist.availability</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage artist availability schedules</field>
    </record>
</odoo>
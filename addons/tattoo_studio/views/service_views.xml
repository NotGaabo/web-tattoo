<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tattoo Service List View -->
    <record id="view_tattoo_service_list" model="ir.ui.view">
        <field name="name">tattoo.service.list</field>
        <field name="model">tattoo.service</field>
        <field name="arch" type="xml">
            <list string="Services">
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
                <field name="average_rating"/>
                <field name="total_appointments"/>
            </list>
        </field>
    </record>

    <!-- Tattoo Service Form View -->
    <record id="view_tattoo_service_form" model="ir.ui.view">
        <field name="name">tattoo.service.form</field>
        <field name="model">tattoo.service</field>
        <field name="arch" type="xml">
            <form string="Service">
                <sheet>
                    <h1>
                        <field name="name" placeholder="Service Name"/>
                    </h1>
                    <group>
                        <group string="Service Details">
                            <field name="description"/>
                            <field name="active"/>
                        </group>
                        <group string="Statistics">
                            <field name="average_rating"/>
                            <field name="total_appointments"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reviews" name="reviews">
                            <field name="review_ids" readonly="1">
                                <list>
                                    <field name="customer_id"/>
                                    <field name="rating"/>
                                    <field name="review_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_service" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">tattoo.service</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage tattoo services</field>
    </record>
</odoo>

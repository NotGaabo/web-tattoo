<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tattoo Exception List View -->
    <record id="view_tattoo_exception_list" model="ir.ui.view">
        <field name="name">tattoo.exception.list</field>
        <field name="model">tattoo.exception</field>
        <field name="arch" type="xml">
            <list string="Exceptions">
                <field name="artist_id"/>
                <field name="date"/>
                <field name="reason"/>
                <field name="is_closed"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Tattoo Exception Form View -->
    <record id="view_tattoo_exception_form" model="ir.ui.view">
        <field name="name">tattoo.exception.form</field>
        <field name="model">tattoo.exception</field>
        <field name="arch" type="xml">
            <form string="Exception">
                <sheet>
                    <group>
                        <field name="artist_id" placeholder="Leave empty for studio-wide"/>
                        <field name="date"/>
                        <field name="reason"/>
                        <field name="is_closed"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_exception" model="ir.actions.act_window">
        <field name="name">Exceptions</field>
        <field name="res_model">tattoo.exception</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage studio/artist exception dates</field>
    </record>
</odoo>
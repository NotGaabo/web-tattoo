<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tattoo Artist List View -->
    <record id="view_tattoo_artist_list" model="ir.ui.view">
        <field name="name">tattoo.artist.list</field>
        <field name="model">tattoo.artist</field>
        <field name="arch" type="xml">
            <list string="Artists">
                <field name="name"/>
                <field name="specialization"/>
                <field name="years_of_experience"/>
                <field name="average_rating"/>
                <field name="total_reviews"/>
                <field name="is_available"/>
            </list>
        </field>
    </record>

    <!-- Tattoo Artist Form View -->
    <record id="view_tattoo_artist_form" model="ir.ui.view">
        <field name="name">tattoo.artist.form</field>
        <field name="model">tattoo.artist</field>
        <field name="arch" type="xml">
            <form string="Artist">
                <sheet>
                    <h1>
                        <field name="name" placeholder="Artist Name"/>
                    </h1>
                    <group>
                        <group string="Contact Information">
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="is_available"/>
                        </group>
                        <group string="Professional Information">
                            <field name="specialization"/>
                            <field name="years_of_experience"/>
                            <field name="average_rating"/>
                            <field name="total_reviews"/>
                            <field name="total_completed_appointments"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Biography" name="biography">
                            <field name="biography"/>
                        </page>
                        <page string="Skills" name="skills">
                            <field name="skill_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Services" name="services">
                            <field name="service_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="service_type"/>
                                    <field name="base_price"/>
                                </list>
                            </field>
                        </page>
                        <page string="Portfolio" name="portfolio">
                            <field name="portfolio_image_ids">
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="image"/>
                                        <field name="tattoo_type"/>
                                    </group>
                                    <field name="description"/>
                                </form>
                            </field>
                        </page>
                        <page string="Appointments" name="appointments">
                            <field name="appointment_ids" readonly="1">
                                <list>
                                    <field name="customer_id"/>
                                    <field name="appointment_datetime"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_artist" model="ir.actions.act_window">
        <field name="name">Artists</field>
        <field name="res_model">tattoo.artist</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage tattoo artists</field>
    </record>
</odoo>

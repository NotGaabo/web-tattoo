<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tattoo Order List View -->
    <record id="view_tattoo_order_list" model="ir.ui.view">
        <field name="name">tattoo.order.list</field>
        <field name="model">tattoo.order</field>
        <field name="arch" type="xml">
            <list string="Orders" decoration-success="state=='done'" decoration-danger="state=='cancelled'">
                <field name="order_number"/>
                <field name="customer_id"/>
                <field name="order_date"/>
                <field name="total_amount"/>
                <field name="state"/>
                <field name="payment_state"/>
            </list>
        </field>
    </record>

    <!-- Tattoo Order Form View -->
    <record id="view_tattoo_order_form" model="ir.ui.view">
        <field name="name">tattoo.order.form</field>
        <field name="model">tattoo.order</field>
        <field name="arch" type="xml">
            <form string="Order">
                <header>
    <button name="action_confirm" string="Confirm" type="object"
        invisible="state != 'draft'" class="btn-primary"/>

    <button name="action_process" string="Process" type="object"
        invisible="state != 'confirmed'" class="btn-primary"/>

    <button name="action_ship" string="Ship" type="object"
        invisible="state != 'processing'" class="btn-primary"/>

    <button name="action_deliver" string="Deliver" type="object"
        invisible="state != 'shipped'" class="btn-primary"/>

    <button name="action_cancel" string="Cancel" type="object"
        invisible="state not in ('draft','confirmed')" class="btn-secondary"/>

    <field name="state" widget="statusbar"
        statusbar_visible="draft,confirmed,processing,shipped,done"/>
</header>
                <sheet>
                    <h1>
                        <field name="order_number"/>
                    </h1>
                    <group>
                        <group string="Order Information">
                            <field name="customer_id"/>
                            <field name="order_date"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Payment">
                            <field name="payment_method"/>
                            <field name="payment_state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines" name="order_lines">
                            <field name="order_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="discount_percentage"/>
                                    <field name="subtotal"/>
                                </list>
                            </field>
                        </page>
                        <page string="Delivery" name="delivery">
                            <group>
                                <group>
                                    <field name="delivery_address"/>
                                    <field name="delivery_date"/>
                                    <field name="delivery_state"/>
                                </group>
                            </group>
                        </page>
                        <page string="Totals" name="totals">
                            <group>
                                <group>
                                    <field name="total_quantity"/>
                                    <field name="subtotal"/>
                                    <field name="tax_amount"/>
                                    <field name="total_amount"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_order" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">tattoo.order</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage product orders</field>
    </record>
</odoo>

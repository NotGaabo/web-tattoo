<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tattoo_contact_request_list" model="ir.ui.view">
        <field name="name">tattoo.contact.request.list</field>
        <field name="model">tattoo.contact.request</field>
        <field name="arch" type="xml">
            <list string="Contact Requests">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="subject"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_tattoo_contact_request_form" model="ir.ui.view">
        <field name="name">tattoo.contact.request.form</field>
        <field name="model">tattoo.contact.request</field>
        <field name="arch" type="xml">
            <form string="Contact Request">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="new,in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="user_id" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="subject"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="message"/>
                        <field name="whatsapp_message" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tattoo_contact_request" model="ir.actions.act_window">
        <field name="name">Contact Requests</field>
        <field name="res_model">tattoo.contact.request</field>
        <field name="view_mode">list,form</field>
        <field name="help">Manage website contact requests sent by portal users</field>
    </record>
</odoo>
